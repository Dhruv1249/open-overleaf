{
  "name": "open-overleaf",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"next,lsp\" --prefix-colors \"cyan,yellow\" \"next dev\" \"npm run dev:lsp\"",
    "dev:next": "next dev",
    "dev:lsp": "fuser -k 3100/tcp 2>/dev/null; sleep 0.3; node texlab-bridge.js",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "mcp": "ts-node mcp-server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@monaco-editor/react": "^4.4.6",
    "concurrently": "^10.0.3",
    "jsonwebtoken": "9.0.0",
    "next": "^16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "vscode-jsonrpc": "^9.0.0",
    "vscode-languageserver-protocol": "^3.18.0",
    "vscode-ws-jsonrpc": "^3.5.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
